        "to": "user@example.com",
        "subject": "Tech-Aggregat",
        "body": "{{input}}"
      }
    },
    {
      "id": "n_t28_07",
      "type": "skill",
      "x": 1100,
      "y": 250,
      "name": "Notiz speichern",
      "config": {
        "skill": "notiz_speichern",
        "text": "{{input}}",
        "datei": "rss_aggregat.txt"
      }
    }
