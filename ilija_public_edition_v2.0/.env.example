# ======================================================
#  Ilija Public Edition - Konfiguration
#  Kopieren: cp .env.example .env
#  WICHTIG: .env NIEMALS oeffentlich teilen!
# ======================================================

# -- KI-Provider (mindestens einen eintragen) ----------

# Anthropic Claude (Beste Qualitaet)
# Key holen: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-api03-xxx...

# Google Gemini (Gut & guenstig, EMPFOHLEN)
# Key holen: https://aistudio.google.com/app/apikey
#GOOGLE_API_KEY=AIzaSy-xxx...

# OpenAI ChatGPT
# Key holen: https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-proj-xxx...

# Ollama (lokal, kein Key noetig)
# Installieren: https://ollama.com -> dann: ollama pull qwen2.5:7b
#OLLAMA_MODEL=qwen2.5:7b

# -- Modell-Auswahl (optional) -------------------------
#ANTHROPIC_MODEL=claude-opus-4-6
#GOOGLE_MODEL=gemini-2.5-flash
#OPENAI_MODEL=gpt-4o
#OLLAMA_MODEL=qwen2.5:7b

# -- Telegram Bot (optional) ---------------------------
# Bot erstellen: Telegram -> @BotFather -> /newbot
#TELEGRAM_BOT_TOKEN=1234567890:AAH-xxx...
# Deine Telegram User-ID (bei @userinfobot erfragen)
#TELEGRAM_ALLOWED_USERS=123456789

# -- Server (optional) ---------------------------------
#PORT=5000
#DEBUG=false

# -- FritzBox Telefon-Assistent (optional) -------------
# SIP-Zugangsdaten aus der FritzBox-Oberflaeche:
#   Telefonie -> Eigene Rufnummern -> IP-Telefonie
#SIP_SERVER=fritz.box
#SIP_PORT=5060
#SIP_USER=deine_interne_rufnummer
#SIP_PASSWORD=dein_sip_passwort
# Lokale IP (leer lassen = automatisch ermitteln):
#SIP_MY_IP=192.168.178.xx
# Mikrofon-Geraete-ID (0 = Standard):
#SIP_MIC_ID=0
# RTP-Port-Bereich (UDP, in FritzBox freigeben):
#SIP_RTP_LOW=10000
#SIP_RTP_HIGH=10100

# -- Google Custom Search API (optional) ---------------
# Fuer gezielte Web-Suche via Google (statt DuckDuckGo)
# Key: https://developers.google.com/custom-search/
#GOOGLE_SEARCH_API_KEY=AIzaSy-xxx...
# Search Engine ID: https://programmablesearchengine.google.com/
#GOOGLE_SEARCH_CX=xxxxxxxxxxxxxxxxx
